{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/src/index.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/waiter",
      "dest": "/frontend/dist/waiter.html"
    },
    {
      "src": "/waiter\\.html",
      "dest": "/frontend/dist/waiter.html"
    },
    {
      "src": "/admin",
      "dest": "/frontend/dist/admin.html"
    },
    {
      "src": "/admin\\.html",
      "dest": "/frontend/dist/admin.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}
