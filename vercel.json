{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/src/index.ts" },
    { "source": "/waiter", "destination": "frontend/waiter.html" },
    { "source": "/admin", "destination": "frontend/admin.html" },
    { "source": "/assets/(.*)", "destination": "frontend/assets/$1" },
    { "source": "/(.*)", "destination": "frontend/index.html" }
  ],
  "builds": [
    {
      "src": "backend/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ]
}
